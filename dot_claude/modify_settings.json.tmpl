#!/bin/bash
set -euo pipefail

# Managed Claude Code settings (merges with existing file, preserving unmanaged keys like hooks)
managed='
{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SHELL": "/bin/zsh"
  },
  "attribution": {
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/bin/starship-claude",
    "padding": 0
  },
  "enabledPlugins": {
{{- range $i, $p := .claude_plugins }}
    "{{ $p.name }}@{{ $p.marketplace }}": true{{ if not (eq $i (sub (len $.claude_plugins) 1)) }},{{ end }}
{{- end }}
  },
  "effortLevel": "high"
}
'

# Read current file from stdin; merge managed keys while preserving unmanaged ones (e.g. hooks)
current="$(cat)"
if [ -n "$current" ]; then
  echo "$current" | jq --argjson managed "$managed" '. + $managed'
else
  echo "$managed" | jq .
fi
